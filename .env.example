# =============================================================================
# Insique — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust for your environment.
# Required variables are marked. All others have safe defaults.
# =============================================================================

# ---- Application ----
APP_NAME=Insique
PROJECT_NAME=Insique
ENVIRONMENT=development              # "development" | "staging" | "production"
DEBUG=false                          # Must be false in production

# ---- API ----
API_V1_PREFIX=/api/v1

# ---- Authentication (REQUIRED) ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Database (REQUIRED) ----
# Production example:
#   DATABASE_URL=postgresql+psycopg://user:password@host:5432/signalforge
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/signalforge

# ---- CORS (REQUIRED for production) ----
# Production example:
#   CORS_ORIGINS=["https://insique.app","https://www.insique.app"]
# Development default:
#   CORS_ORIGINS=["http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# ---- Market Data ----
MARKET_DATA_CACHE_DAYS=7

# ---- Rate Limiting ----
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

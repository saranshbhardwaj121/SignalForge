APP_NAME=SignalForge
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=SignalForge
DEBUG=true
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=signalforge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-db-password
DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@<db_host>:5432/<db_name>
JWT_ALGORITHM=HS256
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]
MARKET_DATA_CACHE_DAYS=7
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
